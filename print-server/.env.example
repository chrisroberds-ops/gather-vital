# Gather Print Server — environment variables
# Copy this file to print-server/.env and fill in your values.

# ── PrintNode ──────────────────────────────────────────────────────────────────
# Sign up at https://www.printnode.com (free up to 500 jobs/month on trial).
# Find your API key at: Account → API Keys.
PRINTNODE_API_KEY=your_printnode_api_key_here

# Your printer's ID. Find it at: https://api.printnode.com/printers
# or run:  curl -u your_api_key: https://api.printnode.com/printers
PRINTNODE_PRINTER_ID=12345

# Optional: separate printers for child labels vs parent tags
# If omitted, both print to PRINTNODE_PRINTER_ID.
PRINTNODE_CHILD_PRINTER_ID=
PRINTNODE_PARENT_PRINTER_ID=

# ── Server ────────────────────────────────────────────────────────────────────
# Port the print server listens on (must match VITE_PRINT_SERVER_URL in Gather's .env.local)
PORT=3001

# CORS: the origin of your Gather web app
ALLOWED_ORIGIN=http://localhost:5173
