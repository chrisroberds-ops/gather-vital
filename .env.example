# Gather — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── App mode ──────────────────────────────────────────────────────────────────
# Set to "true" for local development without Firebase. Uses in-memory seed data.
VITE_TEST_MODE=true

# ── Firebase ──────────────────────────────────────────────────────────────────
# Required in production (leave blank when VITE_TEST_MODE=true).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# ── Email — Resend (https://resend.com) ───────────────────────────────────────
# Free tier: 3,000 emails/month. Sign up → API Keys → create a key.
# Used for waitlist promotion notifications and visitor follow-ups.
# If left blank, emails are skipped with a console.warn (app continues normally).
#
# ⚠ This key is included in the browser bundle. For production deployments that
# handle sensitive data, proxy the Resend call through a Firebase Cloud Function
# and set the key server-side instead.
VITE_RESEND_API_KEY=
# The "from" address shown to recipients. Must be a verified Resend domain.
VITE_RESEND_FROM=Gather <notifications@yourchurch.com>

# ── SMS — Twilio (server-side proxy required) ─────────────────────────────────
# Twilio credentials must NOT be exposed in the browser bundle.
# Wire up a Firebase Cloud Function or server endpoint that accepts
# { to, body } and calls Twilio, then point VITE_TWILIO_PROXY_URL at it.
# Until configured, SMS is skipped with a console.warn (app continues normally).
VITE_TWILIO_PROXY_URL=
# Store these in your server environment (not here):
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567

# ── Label printing ────────────────────────────────────────────────────────────
# URL of the local Gather print server (see print-server/index.js).
# Defaults to http://localhost:3001 if not set.
VITE_PRINT_SERVER_URL=http://localhost:3001

# ── Misc ──────────────────────────────────────────────────────────────────────
VITE_CHURCH_NAME=Community Church
